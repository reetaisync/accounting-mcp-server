{
  "name": "accounting-mcp-server",
  "version": "0.1.0",
  "description": "Production-ready Model Context Protocol (MCP) server for accounting platforms.",
  "author": "ReetAI",
  "license": "MIT",
  "type": "module",
  "main": "dist/app/index.js",
    "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/app/index.ts",
    "build": "tsc",
    "start": "node ./dist/app/index.js",
    "clean": "rm -rf dist",
    "lint": "eslint .",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "check": "npm run typecheck && npm run lint && npm run test",
    "prepare": "husky"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/reetaisync/accounting-mcp-server.git"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "quickbooks",
    "accounting",
    "ai",
    "typescript",
    "fastify",
    "llm",
    "claude",
    "cursor"
  ],
  "bugs": {
    "url": "https://github.com/reetaisync/accounting-mcp-server/issues"
  },
  "homepage": "https://github.com/reetaisync/accounting-mcp-server#readme",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^17.4.2",
    "fastify": "^5.9.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.1.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "prettier": "^3.9.4",
    "tsx": "^4.23.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
