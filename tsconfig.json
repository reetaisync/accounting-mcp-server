{
  "compilerOptions": {
    /* Language */
    "target": "ES2023",
    "lib": ["ES2023"],

    /* Modules */
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    /* Paths */
    "rootDir": "./src",
    "outDir": "./dist",
    
    /* Type Checking */
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,

    /* Build */
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "incremental": true,

    /* Interop */
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,

    /* Types */
    "types": ["node"],

    /* Misc */
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },

  "include": ["src/**/*"],

  "exclude": [
    "node_modules",
    "dist",
    "coverage"
  ]
}